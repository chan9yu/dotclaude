{
  "$schema": "https://json.schemastore.org/claude-code-settings.json",
  "cleanupPeriodDays": 90,
  "env": {
    "CLAUDE_CODE_EXPERIMENTAL_AGENT_TEAMS": "1",
    "ENABLE_PROMPT_CACHING_1H": "1"
  },
  "includeCoAuthoredBy": true,
  "permissions": {
    "allow": [
      "Bash",
      "Edit",
      "NotebookEdit",
      "Skill",
      "WebFetch",
      "WebSearch",
      "Write",
      "Read",
      "Glob",
      "Grep"
    ],
    "deny": [
      "Bash(sudo :*)",
      "Bash(rm -rf :*)",
      "Bash(rm -rf /:*)",
      "Bash(chmod 777 :*)",
      "Bash(chmod -R 777 :*)",
      "Bash(mkfs.:*)",
      "Bash(dd :*)",
      "Bash(:* > /dev/sda*)",
      "Bash(curl *| bash*)",
      "Bash(curl *| sh*)",
      "Bash(wget *| bash*)",
      "Bash(wget *| sh*)",
      "Bash(eval :*)",
      "Bash(git push --force :*)",
      "Bash(git push -f :*)",
      "Bash(git push --force-with-lease :*)",
      "Bash(git push --force* origin main*)",
      "Bash(git push --force* origin master*)",
      "Bash(git reset --hard :*)",
      "Bash(git clean -fd :*)",
      "Bash(git checkout -- :*)",
      "Bash(git branch -D :*)",
      "Bash(killall :*)",
      "Bash(pkill -9 :*)",
      "Bash(npm publish :*)",
      "Bash(pnpm publish :*)",
      "Bash(yarn publish :*)",
      "Read(**/.env)",
      "Read(**/.env.*)",
      "Read(**/secrets/**)",
      "Read(**/.ssh/**)",
      "Read(**/.aws/credentials)",
      "Read(**/credentials.json)"
    ],
    "ask": [
      "Bash(git push :*)",
      "Bash(git push origin main*)",
      "Bash(git push origin master*)",
      "Bash(git merge :*)",
      "Bash(git rebase :*)",
      "Bash(git tag :*)",
      "Bash(npm install :*)",
      "Bash(pnpm install :*)",
      "Bash(npm uninstall :*)",
      "Bash(brew install :*)",
      "Bash(brew uninstall :*)"
    ],
    "defaultMode": "auto"
  },
  "hooks": {
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "bash ~/.claude/hooks/discord-notify.sh",
            "timeout": 10
          }
        ]
      }
    ],
    "Notification": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "bash ~/.claude/hooks/discord-notify.sh",
            "timeout": 10
          }
        ]
      }
    ],
    "TaskCompleted": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "bash ~/.claude/hooks/discord-notify.sh",
            "timeout": 10
          }
        ]
      }
    ]
  },
  "statusLine": {
    "type": "command",
    "command": "node ${CLAUDE_CONFIG_DIR:-$HOME/.claude}/hud/omc-hud.mjs"
  },
  "enabledPlugins": {
    "frontend-design@claude-plugins-official": true,
    "skill-creator@claude-plugins-official": true,
    "superpowers@claude-plugins-official": true,
    "typescript-lsp@claude-plugins-official": true,
    "harness@harness-marketplace": false,
    "oh-my-claudecode@omc": true
  },
  "extraKnownMarketplaces": {
    "harness-marketplace": {
      "source": {
        "source": "github",
        "repo": "revfactory/harness"
      }
    },
    "omc": {
      "source": {
        "source": "git",
        "url": "https://github.com/Yeachan-Heo/oh-my-claudecode.git"
      }
    }
  },
  "outputStyle": "Explanatory",
  "viewMode": "default",
  "language": "korean",
  "alwaysThinkingEnabled": true,
  "effortLevel": "xhigh",
  "autoCompactWindow": 1000000,
  "autoUpdatesChannel": "latest",
  "tui": "fullscreen",
  "autoMemoryEnabled": true,
  "autoDreamEnabled": true,
  "showThinkingSummaries": true,
  "skipDangerousModePermissionPrompt": true,
  "teammateMode": "tmux",
  "skipAutoPermissionPrompt": true,
  "installMethod": "native",
  "model": "opus[1m]"
}
