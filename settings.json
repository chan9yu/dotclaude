{
  "$schema": "https://json.schemastore.org/claude-code-settings.json",
  "cleanupPeriodDays": 90,
  "env": {
    "CLAUDE_CODE_EXPERIMENTAL_AGENT_TEAMS": "1",
    "CLAUDE_CODE_EFFORT_LEVEL": "max",
    "CLAUDE_CODE_DISABLE_ADAPTIVE_THINKING": "1",
    "CLAUDE_CODE_DISABLE_1M_CONTEXT": "1"
  },
  "permissions": {
    "allow": [
      "Bash",
      "Edit",
      "NotebookEdit",
      "Skill",
      "WebFetch",
      "WebSearch",
      "Write",
      "Read",
      "Glob",
      "Grep"
    ],
    "deny": [
      "Bash(sudo :*)",
      "Bash(rm -rf :*)",
      "Bash(chmod 777 :*)",
      "Bash(mkfs.:*)",
      "Bash(dd :*)",
      "Bash(curl *| bash*)",
      "Bash(curl *| sh*)",
      "Bash(wget *| bash*)",
      "Bash(wget *| sh*)",
      "Bash(git push --force :*)",
      "Bash(git push -f :*)",
      "Bash(git push --force-with-lease :*)",
      "Bash(git reset --hard :*)",
      "Bash(git clean -fd :*)",
      "Bash(git checkout -- :*)",
      "Bash(killall :*)",
      "Bash(pkill -9 :*)",
      "Bash(npm publish :*)",
      "Read(**/.env)",
      "Read(**/.env.*)",
      "Read(**/secrets/**)",
      "Read(**/credentials.json)"
    ],
    "ask": [
      "Bash(git push :*)",
      "Bash(git merge :*)",
      "Bash(git rebase :*)"
    ],
    "defaultMode": "plan"
  },
  "model": "opusplan",
  "hooks": {
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "bash ~/.claude/hooks/discord-notify.sh",
            "timeout": 10
          }
        ]
      }
    ],
    "Notification": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "bash ~/.claude/hooks/discord-notify.sh",
            "timeout": 10
          }
        ]
      }
    ],
    "TaskCompleted": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "bash ~/.claude/hooks/discord-notify.sh",
            "timeout": 10
          }
        ]
      }
    ]
  },
  "statusLine": {
    "type": "command",
    "command": "node $HOME/.claude/hud/omc-hud.mjs"
  },
  "enabledPlugins": {
    "frontend-design@claude-plugins-official": true,
    "skill-creator@claude-plugins-official": true,
    "oh-my-claudecode@omc": true,
    "codex@openai-codex": true,
    "harness@harness-marketplace": false,
    "pm-toolkit@pm-skills": false,
    "pm-product-strategy@pm-skills": false,
    "pm-product-discovery@pm-skills": false,
    "pm-market-research@pm-skills": false,
    "pm-data-analytics@pm-skills": false,
    "pm-marketing-growth@pm-skills": false,
    "pm-go-to-market@pm-skills": false,
    "pm-execution@pm-skills": false
  },
  "extraKnownMarketplaces": {
    "harness-marketplace": {
      "source": {
        "source": "github",
        "repo": "revfactory/harness"
      }
    },
    "openai-codex": {
      "source": {
        "source": "github",
        "repo": "openai/codex-plugin-cc"
      }
    },
    "omc": {
      "source": {
        "source": "git",
        "url": "https://github.com/Yeachan-Heo/oh-my-claudecode.git"
      }
    },
    "pm-skills": {
      "source": {
        "source": "github",
        "repo": "phuryn/pm-skills"
      }
    }
  },
  "outputStyle": "Explanatory",
  "language": "korean",
  "effortLevel": "high",
  "skipDangerousModePermissionPrompt": true,
  "teammateMode": "tmux",
  "installMethod": "native"
}
